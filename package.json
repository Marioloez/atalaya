{
  "name": "atalaya",
  "displayName": "Atalaya",
  "description": "Audit-friendly SQLite viewer for VSCode. Browse, query, edit, and export .db / .sqlite / .sqlite3 files. One runtime dependency, no native code.",
  "version": "0.0.10",
  "publisher": "Marioloez",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Data Science",
    "Other"
  ],
  "keywords": [
    "sqlite",
    "sqlite3",
    "database",
    "viewer",
    "db",
    "sql",
    "csv",
    "json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Marioloez/atalaya.git"
  },
  "bugs": {
    "url": "https://github.com/Marioloez/atalaya/issues"
  },
  "homepage": "https://github.com/Marioloez/atalaya#readme",
  "galleryBanner": {
    "color": "#0E639C",
    "theme": "dark"
  },
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "atalaya.viewer",
        "displayName": "Atalaya",
        "selector": [
          { "filenamePattern": "*.db" },
          { "filenamePattern": "*.sqlite" },
          { "filenamePattern": "*.sqlite3" }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -w -p .",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/sql.js": "^1.4.9",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.3.3"
  }
}
